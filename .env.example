# Copy to .env and fill in. Never commit the real .env.

# Hugging Face token (write scope) for model downloads, Dataset persistence, Space push.
HF_TOKEN=hf_xxx

# Serving profile: local | cloud | zerogpu | cpu | fake
RAG_PROFILE=local

# Precision: always bf16/fp16 (never weight-quantize). Verified: full stack fits GPU at ~8.1/11.94 GB.
RAG_DTYPE=bfloat16
RAG_QUANTIZATION=none
RAG_KV_QUANT=polarquant
RAG_RERANKER_DEVICE=cuda

# Vector store: faiss | numpy | pgvector | qdrant   (local default faiss)
RAG_VECTORSTORE=faiss
# Record store (chats/documents/chunks): sqlite | postgres   (local default sqlite)
RAG_RECORD_STORE=sqlite
# Blob store (raw original files): local | supabase   (local default local)
RAG_BLOB_STORE=local

# Memory: off | conversation | semantic | full
RAG_MEMORY=full

# Logging
RAG_LOG_LEVEL=INFO
RAG_LOG_JSON=false

# Hosted persistence — Supabase (Postgres + pgvector + Storage). Secrets: keep only in .env.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_PUBLISHABLE_KEY=
DATABASE_URL=

# Optional alternative hosted vector DB (free Qdrant Cloud)
QDRANT_URL=
QDRANT_API_KEY=

# Grafana Cloud observability (logs via Loki push; metrics via Alloy remote_write). Token: keep only in .env.
RAG_LOKI_URL=
RAG_LOKI_USER=
RAG_PROM_URL=
RAG_PROM_USER=
RAG_GRAFANA_TOKEN=
