# Copy to .env and fill in. Never commit the real .env.

# Hugging Face token (write scope) for model downloads, Dataset persistence, Space push.
HF_TOKEN=hf_xxx

# Serving profile: local | cloud | zerogpu | cpu | fake
RAG_PROFILE=local

# Quantization (local GPU): RAG_QUANTIZATION none|4bit|8bit ; RAG_KV_QUANT polarquant|none
RAG_QUANTIZATION=none
RAG_KV_QUANT=polarquant
RAG_RERANKER_DEVICE=cuda

# Vector store: faiss | numpy | qdrant
RAG_VECTORSTORE=faiss

# Memory: off | conversation | semantic | full
RAG_MEMORY=full

# Logging
RAG_LOG_LEVEL=INFO
RAG_LOG_JSON=false

# Optional hosted vector DB (free Qdrant Cloud)
QDRANT_URL=
QDRANT_API_KEY=

# Optional Grafana Cloud (else use the local docker-compose stack)
RAG_LOKI_URL=
